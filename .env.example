APP_NAME=Mental Model Generator
ENVIRONMENT=development

# Local SQLite development database.
DATABASE_URL=sqlite:///./data/mental_model_generator.db

# PostgreSQL example for local/AWS-style runtime.
# DATABASE_URL=postgresql+psycopg://app_user:change-me@localhost:5432/mental_model_generator

HOST=0.0.0.0
PORT=8000

# Required outside development.
BACKEND_API_KEY=replace-with-a-generated-admin-api-key

# External provider keys.
OPENAI_API_KEY=replace-with-openai-api-key
FIRECRAWL_API_KEY=replace-with-firecrawl-api-key

FIRECRAWL_FORMATS=markdown
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
EXTRACTION_MODEL=gpt-4o
SECTION_MODEL=gpt-4o-mini

# Comma-delimited list. Wildcards are rejected outside development.
CORS_ORIGINS=http://localhost:3000
EXPOSE_API_DOCS=true

# File logging defaults to true in development and false in production.
ENABLE_FILE_LOGGING=true

# Non-SQLite SQLAlchemy pool defaults.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=1800
